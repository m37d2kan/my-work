//@version=5
strategy("SwingFusion Strategy v4.0 - MA Slope Pullback", overlay=true,
     initial_capital=1000000, default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.cash_per_order, commission_value=50,
     slippage=5, pyramiding=0, calc_on_every_tick=false,
     process_orders_on_close=true, close_entries_rule="ANY",
     max_labels_count=500, max_lines_count=500)

// ══════════════════════════════════════════════════════════════
// ① スイング設定 (P&B)
// ══════════════════════════════════════════════════════════════
grpSwing = "① スイング設定"
length1 = input.int(7,  "SW1 ルックバック", minval=1, group=grpSwing)
length2 = input.int(28, "SW2 ルックバック", minval=1, group=grpSwing)
showPB1 = input.bool(true, "P&B1 シグナル表示", group=grpSwing)
showPB2 = input.bool(true, "P&B2 シグナル表示", group=grpSwing)

// ══════════════════════════════════════════════════════════════
// ② 移動平均線
// ══════════════════════════════════════════════════════════════
grpMA = "② 移動平均線"
smaLen1 = input.int(20,  "短期MA期間", minval=1, group=grpMA)
smaLen2 = input.int(80,  "中期MA期間", minval=1, group=grpMA)
smaLen3 = input.int(200, "長期MA期間", minval=1, group=grpMA)

sma1 = ta.sma(close, smaLen1)
sma2 = ta.sma(close, smaLen2)
sma3 = ta.sma(close, smaLen3)

// ══════════════════════════════════════════════════════════════
// ③ MA傾斜設定
// ══════════════════════════════════════════════════════════════
grpSlope = "③ MA傾斜設定"
slopeLen      = input.int(3,   "傾斜算出バー数", minval=1, maxval=20, group=grpSlope)
flatThreshold = input.float(0.3, "80MAフラット判定 (ATR倍率/100バー)", minval=0.05, maxval=2.0, step=0.05, group=grpSlope)

// ══════════════════════════════════════════════════════════════
// ④ プルバック設定
// ══════════════════════════════════════════════════════════════
grpPB = "④ プルバック設定"
pbZone       = input.float(0.5, "20MAプルバックゾーン (ATR倍率)", minval=0.1, maxval=3.0, step=0.1, group=grpPB)
requireCross = input.bool(true, "事前の20MAクロスを要求", group=grpPB)
crossLookback = input.int(30, "クロス検知ルックバック (バー)", minval=5, maxval=100, group=grpPB)
minAwayBars  = input.int(3,  "クロス後の最低離脱バー数", minval=1, maxval=20, group=grpPB)
minAwayDist  = input.float(0.8, "離脱時の最低距離 (ATR倍率)", minval=0.1, maxval=5.0, step=0.1, group=grpPB)
pbTrigger    = input.string("P&B1", "プルバックトリガー",
     options=["P&B1", "P&B2", "P&B1 or P&B2", "20MAタッチのみ"], group=grpPB)

// ══════════════════════════════════════════════════════════════
// ⑤ フェーズ・フィルター設定
// ══════════════════════════════════════════════════════════════
grpPhase = "⑤ フェーズ・フィルター設定"
skipFlat      = input.bool(true, "80MAフラット時トレード禁止", group=grpPhase)
earlyPhaseTP  = input.string("80MAまで", "初動フェーズ利確",
     options=["80MAまで", "ATR固定", "同じ"], group=grpPhase)
require200Pos = input.bool(true, "200MA位置フィルター", group=grpPhase)

// ══════════════════════════════════════════════════════════════
// ⑥ エグジット設定
// ══════════════════════════════════════════════════════════════
grpExit = "⑥ エグジット設定"
atrPeriod       = input.int(14, "ATR期間", minval=1, group=grpExit)
slMode          = input.string("SW1レベル", "損切りモード",
     options=["ATR固定", "SW1レベル", "20MAプルバック高安"], group=grpExit)
slMultiplier    = input.float(1.5, "ATR固定SL (ATR倍率)", minval=0.5, maxval=10.0, step=0.5, group=grpExit)
swingSLPadding  = input.float(0.3, "SL余裕 (ATR倍率)", minval=0.0, maxval=2.0, step=0.1, group=grpExit)
slMaxATR        = input.float(3.0, "SL上限 (ATR倍率)", minval=1.0, maxval=10.0, step=0.5, group=grpExit)
tpMultiplier    = input.float(3.0, "利確 (ATR倍率)", minval=0.5, maxval=10.0, step=0.5, group=grpExit)
useTrailing     = input.bool(false, "トレーリングストップ", group=grpExit)
trailMultiplier = input.float(2.0, "トレーリング (ATR倍率)", minval=0.5, maxval=10.0, step=0.5, group=grpExit)
exitOnPBReverse = input.bool(true, "SW1逆波動で決済", group=grpExit)
exitOn20MACross = input.bool(false, "20MA逆クロスで決済", group=grpExit)

// ══════════════════════════════════════════════════════════════
// ⑦ 時間フィルター
// ══════════════════════════════════════════════════════════════
grpTime = "⑦ 時間フィルター"
useTimeFilter     = input.bool(true, "時間制限 ON/OFF", group=grpTime)
startHour         = input.int(8,  "開始（時）", minval=0, maxval=23, group=grpTime)
startMin          = input.int(45, "開始（分）", minval=0, maxval=59, group=grpTime)
endHour           = input.int(15, "終了（時）", minval=0, maxval=23, group=grpTime)
endMin            = input.int(30, "終了（分）", minval=0, maxval=59, group=grpTime)
closeAtSessionEnd = input.bool(true, "セッション終了時に全決済", group=grpTime)
useOpenFilter     = input.bool(true, "寄付き除外 ON/OFF", group=grpTime)
openExcludeMin    = input.int(15, "寄付き除外（分）", minval=5, maxval=60, step=5, group=grpTime)

// ══════════════════════════════════════════════════════════════
// ATR・傾斜計算
// ══════════════════════════════════════════════════════════════
atrValue = ta.atr(atrPeriod)

float slope1 = sma1 - sma1[slopeLen]
float slope2 = sma2 - sma2[slopeLen]
float slope3 = sma3 - sma3[slopeLen]

// 傾斜方向
bool sma1Up = slope1 > 0
bool sma1Dn = slope1 < 0
bool sma2Up = slope2 > 0
bool sma2Dn = slope2 < 0
bool sma3Up = slope3 > 0
bool sma3Dn = slope3 < 0

// 傾斜転換検知
bool sma1TurnUp = sma1Up and not sma1Up[1]
bool sma1TurnDn = sma1Dn and not sma1Dn[1]
bool sma2TurnUp = sma2Up and not sma2Up[1]
bool sma2TurnDn = sma2Dn and not sma2Dn[1]

// 80MAフラット判定（ATRで正規化）
float slopeNorm2 = atrValue > 0 ? math.abs(slope2) / atrValue * 100 : 0
bool isFlat80 = slopeNorm2 < flatThreshold

// MA色（傾斜に基づく）
color col1 = sma1Up ? color.green : color.red
color col2 = sma2Up ? color.blue : color.red
color col3 = sma3Up ? color.purple : color.red

plot(sma1, "20MA", col1, 2)
plot(sma2, "80MA", col2, 2)
plot(sma3, "200MA", col3, 2)

// ══════════════════════════════════════════════════════════════
// フェーズ判定
// ══════════════════════════════════════════════════════════════
// フェーズ: 0=レンジ, 1=初動, 2=加速, 3=到達
var int phase = 0

bool priceAbove200 = close > sma3
bool priceBelow200 = close < sma3

// 買い方向のフェーズ
bool accelBuy = sma1Up and sma2Up
bool earlyBuy = sma1Up and not sma2Up
bool reachBuy = accelBuy and (math.abs(close - sma3) < atrValue * 2)

// 売り方向のフェーズ
bool accelSell = sma1Dn and sma2Dn
bool earlySell = sma1Dn and not sma2Dn
bool reachSell = accelSell and (math.abs(close - sma3) < atrValue * 2)

if isFlat80
    phase := 0
else if reachBuy or reachSell
    phase := 3
else if accelBuy or accelSell
    phase := 2
else if earlyBuy or earlySell
    phase := 1
else
    phase := 0

// ══════════════════════════════════════════════════════════════
// P&B ロジック
// ══════════════════════════════════════════════════════════════
var string lastPB1 = na
var string lastPB2 = na

bool peakCond1   = low < ta.lowest(low, length1)[1] and lastPB1 != "peak"
bool botCond1    = high > ta.highest(high, length1)[1] and lastPB1 != "bottom"
bool peakCond2   = low < ta.lowest(low, length2)[1] and lastPB2 != "peak"
bool botCond2    = high > ta.highest(high, length2)[1] and lastPB2 != "bottom"

var string pbState1 = "---"
var string pbState2 = "---"

if peakCond1
    lastPB1  := "peak"
    pbState1 := "下落波動"
if botCond1
    lastPB1  := "bottom"
    pbState1 := "上昇波動"
if peakCond2
    lastPB2  := "peak"
    pbState2 := "下落波動"
if botCond2
    lastPB2  := "bottom"
    pbState2 := "上昇波動"

// P&Bプロット
float atrOff1 = atrValue * 0.5
float atrOff2 = atrValue * 0.8
plotshape(showPB1 and peakCond1 ? high + atrOff1 : na, "SW1 Peak", shape.triangledown, location.absolute, color.new(color.orange, 20), size=size.tiny)
plotshape(showPB1 and botCond1 ? low - atrOff1 : na, "SW1 Bot", shape.triangleup, location.absolute, color.new(color.teal, 20), size=size.tiny)
plotshape(showPB2 and peakCond2 ? high + atrOff2 : na, "SW2 Peak", shape.diamond, location.absolute, color.new(color.purple, 20), size=size.tiny)
plotshape(showPB2 and botCond2 ? low - atrOff2 : na, "SW2 Bot", shape.diamond, location.absolute, color.new(color.teal, 20), size=size.tiny)

// ══════════════════════════════════════════════════════════════
// SW1 スイングポイント記録（SL用）
// ══════════════════════════════════════════════════════════════
var float prevPeak1 = na, var float prevBot1 = na
var bool findMin1 = true, var bool findMax1 = false
var float minP1 = na, var float maxP1 = na

if barstate.isconfirmed
    if findMin1 and (na(minP1) or low < minP1)
        minP1 := low
    if findMax1 and (na(maxP1) or high > maxP1)
        maxP1 := high

    if findMax1 and low < ta.lowest(low, length1)[1]
        prevPeak1 := maxP1
        findMax1 := false
        findMin1 := true
        minP1 := low

    if findMin1 and high > ta.highest(high, length1)[1]
        prevBot1 := minP1
        findMin1 := false
        findMax1 := true
        maxP1 := high

// ══════════════════════════════════════════════════════════════
// 20MAクロス・離脱・プルバック検知
// ══════════════════════════════════════════════════════════════
float distTo20MA = close - sma1
float absDist20  = math.abs(distTo20MA)
bool inPBZone    = absDist20 <= atrValue * pbZone

// 20MAを上にクロスした履歴（直近Nバー以内）
// 「上クロス → 上方に離脱 → プルバック」を検知
var int lastCrossUpBar   = na
var int lastCrossDnBar   = na
var float maxDistAfterCrossUp = 0.0
var float maxDistAfterCrossDn = 0.0
var float pbHighAfterCrossDn = na  // 売り時のSL用：プルバック中の高値
var float pbLowAfterCrossUp = na   // 買い時のSL用：プルバック中の安値

bool crossUp = ta.crossover(close, sma1)
bool crossDn = ta.crossunder(close, sma1)

if crossUp
    lastCrossUpBar := bar_index
    maxDistAfterCrossUp := 0.0
    pbLowAfterCrossUp := na

if crossDn
    lastCrossDnBar := bar_index
    maxDistAfterCrossDn := 0.0
    pbHighAfterCrossDn := na

// 上クロス後の最大離脱距離を追跡
if not na(lastCrossUpBar) and close > sma1
    float d = close - sma1
    if d > maxDistAfterCrossUp
        maxDistAfterCrossUp := d

// 下クロス後の最大離脱距離を追跡
if not na(lastCrossDnBar) and close < sma1
    float d = sma1 - close
    if d > maxDistAfterCrossDn
        maxDistAfterCrossDn := d

// プルバック中の高安記録（SL用）
if not na(lastCrossUpBar) and inPBZone and close > sma1
    if na(pbLowAfterCrossUp) or low < pbLowAfterCrossUp
        pbLowAfterCrossUp := low

if not na(lastCrossDnBar) and inPBZone and close < sma1
    if na(pbHighAfterCrossDn) or high > pbHighAfterCrossDn
        pbHighAfterCrossDn := high

// プルバック準備完了判定
bool pbReadyBuy = false
bool pbReadySell = false

if requireCross
    // 買い: 上クロス済み → 離脱 → 20MA付近に戻ってきた
    if not na(lastCrossUpBar)
        int barsSinceCross = bar_index - lastCrossUpBar
        bool withinWindow = barsSinceCross <= crossLookback
        bool wasAway = maxDistAfterCrossUp >= atrValue * minAwayDist
        bool hadMinBars = barsSinceCross >= minAwayBars
        pbReadyBuy := withinWindow and wasAway and hadMinBars and inPBZone and close >= sma1

    // 売り: 下クロス済み → 離脱 → 20MA付近に戻ってきた
    if not na(lastCrossDnBar)
        int barsSinceCross = bar_index - lastCrossDnBar
        bool withinWindow = barsSinceCross <= crossLookback
        bool wasAway = maxDistAfterCrossDn >= atrValue * minAwayDist
        bool hadMinBars = barsSinceCross >= minAwayBars
        pbReadySell := withinWindow and wasAway and hadMinBars and inPBZone and close <= sma1
else
    pbReadyBuy  := inPBZone and close >= sma1
    pbReadySell := inPBZone and close <= sma1

// ══════════════════════════════════════════════════════════════
// トリガー判定
// ══════════════════════════════════════════════════════════════
bool trigBuy  = false
bool trigSell = false

if pbTrigger == "P&B1"
    trigBuy  := botCond1
    trigSell := peakCond1
else if pbTrigger == "P&B2"
    trigBuy  := botCond2
    trigSell := peakCond2
else if pbTrigger == "P&B1 or P&B2"
    trigBuy  := botCond1 or botCond2
    trigSell := peakCond1 or peakCond2
else // 20MAタッチのみ
    trigBuy  := inPBZone and close > sma1 and close[1] <= sma1[1]
    trigSell := inPBZone and close < sma1 and close[1] >= sma1[1]

// ══════════════════════════════════════════════════════════════
// 時間フィルター
// ══════════════════════════════════════════════════════════════
f_inSignalTime() =>
    if not useTimeFilter
        true
    else
        int h = hour(time, "Asia/Tokyo")
        int m = minute(time, "Asia/Tokyo")
        int current = h * 60 + m
        int startM  = startHour * 60 + startMin
        int endM    = endHour * 60 + endMin
        bool inSession = startM <= endM ? (current >= startM and current < endM) : (current >= startM or current < endM)
        bool afterOpen = not useOpenFilter or (current >= startM + openExcludeMin)
        inSession and afterOpen

f_isSessionEnd() =>
    if not closeAtSessionEnd or not useTimeFilter
        false
    else
        int h = hour(time, "Asia/Tokyo")
        int m = minute(time, "Asia/Tokyo")
        int current = h * 60 + m
        int endM    = endHour * 60 + endMin
        current >= endM - 5 and current < endM + 5

// ══════════════════════════════════════════════════════════════
// エントリー条件
// ══════════════════════════════════════════════════════════════
bool timeOK = f_inSignalTime()

bool entryBuy  = false
bool entrySell = false

// 200MAフィルター
bool pos200Buy  = not require200Pos or priceAbove200 or (math.abs(close - sma3) < atrValue * 2)
bool pos200Sell = not require200Pos or priceBelow200 or (math.abs(close - sma3) < atrValue * 2)

if barstate.isconfirmed and timeOK and strategy.position_size == 0
    // ── 買いエントリー ──
    // フェーズ1(初動) or フェーズ2(加速): 20MAプルバック + P&Bトリガー
    if (phase == 1 and earlyBuy or phase == 2 and accelBuy) and not (skipFlat and isFlat80)
        if pbReadyBuy and trigBuy and sma1Up and pos200Buy
            entryBuy := true

    // ── 売りエントリー ──
    if (phase == 1 and earlySell or phase == 2 and accelSell) and not (skipFlat and isFlat80)
        if pbReadySell and trigSell and sma1Dn and pos200Sell
            entrySell := true

// ══════════════════════════════════════════════════════════════
// エントリー・エグジット
// ══════════════════════════════════════════════════════════════
if entryBuy
    // SL計算
    float sl = na
    if slMode == "SW1レベル" and not na(prevBot1)
        sl := prevBot1 - atrValue * swingSLPadding
    else if slMode == "20MAプルバック高安" and not na(pbLowAfterCrossUp)
        sl := pbLowAfterCrossUp - atrValue * swingSLPadding
    else
        sl := close - atrValue * slMultiplier
    sl := math.max(sl, close - atrValue * slMaxATR)

    // TP計算
    float tp = na
    if phase == 1 and earlyPhaseTP == "80MAまで" and not na(sma2) and sma2 > close
        tp := sma2
    else
        tp := close + atrValue * tpMultiplier

    string lbl = phase == 1 ? "初動BUY" : phase == 2 ? "加速BUY" : "BUY"
    strategy.entry("Long", strategy.long, comment=lbl)
    strategy.exit("Long TP/SL", "Long", stop=sl, limit=tp,
         trail_points=useTrailing ? atrValue * trailMultiplier : na,
         trail_offset=useTrailing ? atrValue * 1.0 : na)

if entrySell
    float sl = na
    if slMode == "SW1レベル" and not na(prevPeak1)
        sl := prevPeak1 + atrValue * swingSLPadding
    else if slMode == "20MAプルバック高安" and not na(pbHighAfterCrossDn)
        sl := pbHighAfterCrossDn + atrValue * swingSLPadding
    else
        sl := close + atrValue * slMultiplier
    sl := math.min(sl, close + atrValue * slMaxATR)

    float tp = na
    if phase == 1 and earlyPhaseTP == "80MAまで" and not na(sma2) and sma2 < close
        tp := sma2
    else
        tp := close - atrValue * tpMultiplier

    string lbl = phase == 1 ? "初動SELL" : phase == 2 ? "加速SELL" : "SELL"
    strategy.entry("Short", strategy.short, comment=lbl)
    strategy.exit("Short TP/SL", "Short", stop=sl, limit=tp,
         trail_points=useTrailing ? atrValue * trailMultiplier : na,
         trail_offset=useTrailing ? atrValue * 1.0 : na)

// ── SW1逆波動で決済 ──
if exitOnPBReverse and barstate.isconfirmed
    if strategy.position_size > 0 and peakCond1
        strategy.close("Long", comment="SW1逆転")
    if strategy.position_size < 0 and botCond1
        strategy.close("Short", comment="SW1逆転")

// ── 20MA逆クロスで決済 ──
if exitOn20MACross and barstate.isconfirmed
    if strategy.position_size > 0 and crossDn
        strategy.close("Long", comment="20MA割れ")
    if strategy.position_size < 0 and crossUp
        strategy.close("Short", comment="20MA超え")

// ── セッション終了 ──
if f_isSessionEnd()
    if strategy.position_size != 0
        strategy.close_all(comment="セッション終了")

// ══════════════════════════════════════════════════════════════
// プロット
// ══════════════════════════════════════════════════════════════
plotshape(entryBuy, "BUY", shape.labelup, location.belowbar,
     color.blue, size=size.normal, text="BUY")
plotshape(entrySell, "SELL", shape.labeldown, location.abovebar,
     color.red, size=size.normal, text="SELL")

// 20MAプルバックゾーン
float z1Hi = sma1 + atrValue * pbZone
float z1Lo = sma1 - atrValue * pbZone
pHi = plot(z1Hi, "PB Zone Hi", color.new(color.yellow, 90))
pLo = plot(z1Lo, "PB Zone Lo", color.new(color.yellow, 90))
fill(pHi, pLo, color=color.new(color.yellow, 95), title="20MA PBゾーン")

// プルバック準備完了マーク
plotshape(pbReadyBuy and not entryBuy ? low - atrValue * 0.3 : na, "PB Ready Buy",
     shape.circle, location.absolute, color.new(color.blue, 70), size=size.tiny)
plotshape(pbReadySell and not entrySell ? high + atrValue * 0.3 : na, "PB Ready Sell",
     shape.circle, location.absolute, color.new(color.red, 70), size=size.tiny)

// フェーズ背景色
color phaseBG = na
if phase == 0
    phaseBG := isFlat80 ? color.new(color.gray, 95) : na
else if phase == 1
    phaseBG := (earlyBuy ? color.new(color.blue, 96) : earlySell ? color.new(color.red, 96) : na)
else if phase == 2
    phaseBG := (accelBuy ? color.new(color.blue, 93) : accelSell ? color.new(color.red, 93) : na)
else if phase == 3
    phaseBG := color.new(color.purple, 95)
bgcolor(phaseBG, title="フェーズ")

// ══════════════════════════════════════════════════════════════
// テーブル
// ══════════════════════════════════════════════════════════════
var table tb = table.new(position.bottom_right, 6, 4, border_width=1)

if barstate.islast
    // ── Header ──
    table.cell(tb, 0, 0, "", bgcolor=#333333, text_color=color.white, text_size=size.small)
    table.cell(tb, 1, 0, "傾斜", bgcolor=#333333, text_color=color.white, text_size=size.small)
    table.cell(tb, 2, 0, "価格位置", bgcolor=#333333, text_color=color.white, text_size=size.small)
    table.cell(tb, 3, 0, "距離(ATR)", bgcolor=#333333, text_color=color.white, text_size=size.small)
    table.cell(tb, 4, 0, "P&B1", bgcolor=#333333, text_color=color.white, text_size=size.small)
    table.cell(tb, 5, 0, "P&B2", bgcolor=#333333, text_color=color.white, text_size=size.small)

    // ── 20MA ──
    color s1c = sma1Up ? #009600 : #C80000
    string pos1 = close > sma1 ? "上" : "下"
    float d1 = atrValue > 0 ? (close - sma1) / atrValue : 0
    table.cell(tb, 0, 1, "20MA", bgcolor=#1E50B4, text_color=color.white, text_size=size.small)
    table.cell(tb, 1, 1, sma1Up ? "↑" : "↓", bgcolor=s1c, text_color=color.white, text_size=size.small)
    table.cell(tb, 2, 1, pos1, bgcolor=#464646, text_color=color.white, text_size=size.small)
    table.cell(tb, 3, 1, str.tostring(d1, "#.#"), bgcolor=#464646, text_color=color.white, text_size=size.small)
    table.cell(tb, 4, 1, pbState1, bgcolor=pbState1 == "上昇波動" ? #009600 : #C80000, text_color=color.white, text_size=size.small)
    table.cell(tb, 5, 1, pbState2, bgcolor=pbState2 == "上昇波動" ? #009600 : #C80000, text_color=color.white, text_size=size.small)

    // ── 80MA ──
    color s2c = isFlat80 ? #888888 : (sma2Up ? #0000C8 : #C80000)
    string pos2 = close > sma2 ? "上" : "下"
    float d2 = atrValue > 0 ? (close - sma2) / atrValue : 0
    string flatT = isFlat80 ? " FLAT" : ""
    table.cell(tb, 0, 2, "80MA", bgcolor=#823282, text_color=color.white, text_size=size.small)
    table.cell(tb, 1, 2, (sma2Up ? "↑" : "↓") + flatT, bgcolor=s2c, text_color=color.white, text_size=size.small)
    table.cell(tb, 2, 2, pos2, bgcolor=#464646, text_color=color.white, text_size=size.small)
    table.cell(tb, 3, 2, str.tostring(d2, "#.#"), bgcolor=#464646, text_color=color.white, text_size=size.small)

    // フェーズ表示
    string phaseT = phase == 0 ? "レンジ" : phase == 1 ? "初動" : phase == 2 ? "加速" : "到達"
    color phaseC = phase == 0 ? #888888 : phase == 1 ? #B8860B : phase == 2 ? #006400 : #4B0082
    table.cell(tb, 4, 2, phaseT, bgcolor=phaseC, text_color=color.white, text_size=size.small)

    // PBステータス
    string pbSt = pbReadyBuy ? "PB買準備" : pbReadySell ? "PB売準備" : inPBZone ? "ゾーン内" : "---"
    table.cell(tb, 5, 2, pbSt, bgcolor=#464646, text_color=color.white, text_size=size.small)

    // ── 200MA ──
    color s3c = sma3Up ? #800080 : #C80000
    string pos3 = close > sma3 ? "上" : "下"
    float d3 = atrValue > 0 ? (close - sma3) / atrValue : 0
    table.cell(tb, 0, 3, "200MA", bgcolor=#505050, text_color=color.white, text_size=size.small)
    table.cell(tb, 1, 3, sma3Up ? "↑" : "↓", bgcolor=s3c, text_color=color.white, text_size=size.small)
    table.cell(tb, 2, 3, pos3, bgcolor=#464646, text_color=color.white, text_size=size.small)
    table.cell(tb, 3, 3, str.tostring(d3, "#.#"), bgcolor=#464646, text_color=color.white, text_size=size.small)

    // ポジション情報
    string posT = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    color posC = strategy.position_size > 0 ? #0064C8 : strategy.position_size < 0 ? #C83232 : #646464
    table.cell(tb, 4, 3, posT, bgcolor=posC, text_color=color.white, text_size=size.small)
    string pnl = strategy.position_size != 0 ? str.tostring(strategy.openprofit, "#") : "---"
    table.cell(tb, 5, 3, pnl, bgcolor=#464646, text_color=color.white, text_size=size.small)

// ══════════════════════════════════════════════════════════════
// アラート
// ══════════════════════════════════════════════════════════════
alertcondition(entryBuy,  title="v4 BUY",  message="MA Slope Pullback BUY - {{ticker}} @ {{close}}")
alertcondition(entrySell, title="v4 SELL", message="MA Slope Pullback SELL - {{ticker}} @ {{close}}")