//@version=5
indicator("SW2 Wave Statistics", overlay=false)
// ══════════════════════════════════════════════════════════════
// 設定
// ══════════════════════════════════════════════════════════════
length2      = input.int(20, "Swing2 Look-back Period", minval=1, group="スイング設定")
atrPeriod    = input.int(14, "ATR期間", minval=1, group="スイング設定")
maxTrends    = input.int(20, "統計対象トレンド数", minval=5, maxval=50, group="統計設定")
tablePos     = input.string("top_right", "テーブル位置", options=["top_left", "top_center", "top_right", "bottom_left", "bottom_center", "bottom_right"], group="統計設定")
// ══════════════════════════════════════════════════════════════
// SW2 スイング確定処理
// ══════════════════════════════════════════════════════════════
atrValue = ta.atr(atrPeriod)
var float ssb_maxPrice2   = na
var int   ssb_maxIdx2     = na
var float ssb_minPrice2   = na
var int   ssb_minIdx2     = na
var bool  ssb_findingMin2 = true
var bool  ssb_findingMax2 = false
var float prevPeak2       = na
var float prevPeak2nd2    = na
var float prevBot2        = na
var float prevBot2nd2     = na
var bool  peak_conf2_now   = false
var bool  bottom_conf2_now = false
if barstate.isconfirmed
    if ssb_findingMin2 and (na(ssb_minPrice2) or low < ssb_minPrice2)
        ssb_minPrice2 := low
        ssb_minIdx2   := bar_index
    if ssb_findingMax2 and (na(ssb_maxPrice2) or high > ssb_maxPrice2)
        ssb_maxPrice2 := high
        ssb_maxIdx2   := bar_index
    peak_conf2   = ssb_findingMax2 and low < ta.lowest(low, length2)[1]
    bottom_conf2 = ssb_findingMin2 and high > ta.highest(high, length2)[1]
    peak_conf2_now   := peak_conf2
    bottom_conf2_now := bottom_conf2
    if peak_conf2
        prevPeak2nd2    := prevPeak2
        prevPeak2       := ssb_maxPrice2
        ssb_findingMax2 := false
        ssb_findingMin2 := true
        ssb_minPrice2   := low
        ssb_minIdx2     := bar_index
    if bottom_conf2
        prevBot2nd2     := prevBot2
        prevBot2        := ssb_minPrice2
        ssb_findingMin2 := false
        ssb_findingMax2 := true
        ssb_maxPrice2   := high
        ssb_maxIdx2     := bar_index
else
    peak_conf2_now   := false
    bottom_conf2_now := false
// ══════════════════════════════════════════════════════════════
// 価格構造ベース トレンド判定 & 波動カウント
// ══════════════════════════════════════════════════════════════
var string structTrend    = na       // "Up" or "Down"（価格構造ベース）
var int    waveCount      = 0
var int    trendStartBar  = 0
var float  trendStartPrice = na
var float  trendHighest   = na
var float  trendLowest    = na
var int    hhCount        = 0        // 高値更新(Peak)
var int    hlCount        = 0        // 安値切上(Bot)
var int    lhCount        = 0        // 高値切下(Peak)
var int    llCount        = 0        // 安値更新(Bot)
var int    resCount       = 0        // レス
// ── 完了したトレンドの統計記録用配列 ──
var array<string> hist_dir        = array.new_string(0)
var array<int>    hist_waves      = array.new_int(0)
var array<int>    hist_bars       = array.new_int(0)
var array<float>  hist_pct        = array.new_float(0)
var array<float>  hist_atrRatio   = array.new_float(0)
var array<int>    hist_hhCount    = array.new_int(0)
var array<int>    hist_hlCount    = array.new_int(0)
var array<int>    hist_llCount    = array.new_int(0)
var array<int>    hist_lhCount    = array.new_int(0)
var array<int>    hist_resCount   = array.new_int(0)
// ── トレンド記録関数 ──
f_recordTrend() =>
    if not na(structTrend) and waveCount > 0 and bar_index > trendStartBar + 1
        int   _bars    = bar_index - trendStartBar
        float _endPx   = close
        float _startPx = trendStartPrice
        float _pct     = not na(_startPx) and _startPx > 0 ? (_endPx - _startPx) / _startPx * 100 : 0
        float _range   = structTrend == "Up" ? (not na(trendHighest) and not na(_startPx) ? trendHighest - _startPx : 0) : (not na(_startPx) and not na(trendLowest) ? _startPx - trendLowest : 0)
        float _atrR    = atrValue > 0 ? _range / atrValue : 0
        array.push(hist_dir, structTrend)
        array.push(hist_waves, waveCount)
        array.push(hist_bars, _bars)
        array.push(hist_pct, _pct)
        array.push(hist_atrRatio, _atrR)
        array.push(hist_hhCount, hhCount)
        array.push(hist_hlCount, hlCount)
        array.push(hist_llCount, llCount)
        array.push(hist_lhCount, lhCount)
        array.push(hist_resCount, resCount)
        if array.size(hist_dir) > maxTrends
            array.shift(hist_dir)
            array.shift(hist_waves)
            array.shift(hist_bars)
            array.shift(hist_pct)
            array.shift(hist_atrRatio)
            array.shift(hist_hhCount)
            array.shift(hist_hlCount)
            array.shift(hist_llCount)
            array.shift(hist_lhCount)
            array.shift(hist_resCount)
// ── SW2ピーク確定時 ──
if peak_conf2_now
    waveCount += 1
    if not na(prevPeak2) and not na(prevPeak2nd2)
        if prevPeak2 > prevPeak2nd2
            // 高値更新 → Upトレンドの証拠
            if structTrend != "Up"
                f_recordTrend()
                structTrend     := "Up"
                waveCount       := 1
                trendStartBar   := bar_index
                trendStartPrice := close
                trendHighest    := high
                trendLowest     := low
                hhCount         := 1
                hlCount         := 0
                llCount         := 0
                lhCount         := 0
                resCount        := 0
            else
                hhCount += 1
        else if prevPeak2 < prevPeak2nd2
            // 高値切り下げ
            lhCount += 1
        else
            resCount += 1
    else if na(structTrend)
        structTrend     := "Up"
        waveCount       := 1
        trendStartBar   := bar_index
        trendStartPrice := close
        trendHighest    := high
        trendLowest     := low
// ── SW2ボトム確定時 ──
if bottom_conf2_now
    waveCount += 1
    if not na(prevBot2) and not na(prevBot2nd2)
        if prevBot2 < prevBot2nd2
            // 安値更新 → Downトレンドの証拠
            if structTrend != "Down"
                f_recordTrend()
                structTrend     := "Down"
                waveCount       := 1
                trendStartBar   := bar_index
                trendStartPrice := close
                trendHighest    := high
                trendLowest     := low
                hhCount         := 0
                hlCount         := 0
                llCount         := 1
                lhCount         := 0
                resCount        := 0
            else
                llCount += 1
        else if prevBot2 > prevBot2nd2
            // 安値切り上げ
            hlCount += 1
        else
            resCount += 1
    else if na(structTrend)
        structTrend    := "Down"
        waveCount      := 1
        trendStartBar  := bar_index
        trendStartPrice := close
        trendHighest   := high
        trendLowest    := low
// ── トレンド中の高値/安値追跡 ──
if not na(structTrend)
    if not na(trendHighest)
        trendHighest := math.max(trendHighest, high)
    if not na(trendLowest)
        trendLowest := math.min(trendLowest, low)
// ══════════════════════════════════════════════════════════════
// プロット（サブチャート）
// ══════════════════════════════════════════════════════════════
color waveColor = structTrend == "Up" ? color.blue : structTrend == "Down" ? color.red : color.gray
plot(waveCount, "波動カウント", color=waveColor, linewidth=2, style=plot.style_stepline)
hline(3, "3波", color=color.gray, linestyle=hline.style_dashed)
hline(5, "5波", color=color.orange, linestyle=hline.style_dashed)
hline(7, "7波", color=color.red, linestyle=hline.style_dashed)
bgcolor(waveCount >= 5 ? color.new(color.orange, 85) : na, title="5波以上警告")
bgcolor(waveCount >= 7 ? color.new(color.red, 85) : na, title="7波以上警告")
// ── トレンド転換マーカー ──
bool newUp   = peak_conf2_now and not na(prevPeak2) and not na(prevPeak2nd2) and prevPeak2 > prevPeak2nd2 and structTrend == "Up" and waveCount <= 2
bool newDown = bottom_conf2_now and not na(prevBot2) and not na(prevBot2nd2) and prevBot2 < prevBot2nd2 and structTrend == "Down" and waveCount <= 2
plotshape(newUp ? 0 : na, "Up転換", shape.triangleup, location.absolute, color.blue, size=size.small)
plotshape(newDown ? 0 : na, "Down転換", shape.triangledown, location.absolute, color.red, size=size.small)
// ══════════════════════════════════════════════════════════════
// 統計テーブル
// ══════════════════════════════════════════════════════════════
var table statTable = na
if barstate.islast
    int n = array.size(hist_waves)
    float avgWaves  = 0.0
    float maxWaves  = 0.0
    float minWaves  = 999.0
    float avgBars   = 0.0
    float avgPct    = 0.0
    float avgATR    = 0.0
    float avgHH     = 0.0
    float avgHL     = 0.0
    float avgLL     = 0.0
    float avgLH     = 0.0
    float avgRes    = 0.0
    int   upCount   = 0
    int   dnCount   = 0
    if n > 0
        for i = 0 to n - 1
            float w = array.get(hist_waves, i)
            avgWaves += w
            maxWaves := math.max(maxWaves, w)
            minWaves := math.min(minWaves, w)
            avgBars  += array.get(hist_bars, i)
            avgPct   += math.abs(array.get(hist_pct, i))
            avgATR   += array.get(hist_atrRatio, i)
            avgHH    += array.get(hist_hhCount, i)
            avgHL    += array.get(hist_hlCount, i)
            avgLL    += array.get(hist_llCount, i)
            avgLH    += array.get(hist_lhCount, i)
            avgRes   += array.get(hist_resCount, i)
            if array.get(hist_dir, i) == "Up"
                upCount += 1
            else
                dnCount += 1
        avgWaves := avgWaves / n
        avgBars  := avgBars  / n
        avgPct   := avgPct   / n
        avgATR   := avgATR   / n
        avgHH    := avgHH    / n
        avgHL    := avgHL    / n
        avgLL    := avgLL    / n
        avgLH    := avgLH    / n
        avgRes   := avgRes   / n
    tPos = switch tablePos
        "top_left"      => position.top_left
        "top_center"    => position.top_center
        "top_right"     => position.top_right
        "bottom_left"   => position.bottom_left
        "bottom_center" => position.bottom_center
        "bottom_right"  => position.bottom_right
        => position.top_right
    if na(statTable)
        statTable := table.new(tPos, 3, 16, border_width=1)
    color hdrBG  = color.rgb(50, 50, 50)
    color hdrTx  = color.white
    color rowBG1 = color.rgb(240, 240, 240)
    color rowBG2 = color.rgb(255, 255, 255)
    table.cell(statTable, 0, 0, "SW2 波動統計", bgcolor=hdrBG, text_color=hdrTx, text_size=size.normal)
    table.cell(statTable, 1, 0, "値", bgcolor=hdrBG, text_color=hdrTx, text_size=size.normal)
    table.cell(statTable, 2, 0, "備考", bgcolor=hdrBG, text_color=hdrTx, text_size=size.normal)
    // 現在のトレンド
    color curBG = structTrend == "Up" ? color.rgb(0, 80, 0) : color.rgb(120, 0, 0)
    table.cell(statTable, 0, 1, "現在", bgcolor=curBG, text_color=color.white, text_size=size.normal)
    table.cell(statTable, 1, 1, str.tostring(structTrend) + " W" + str.tostring(waveCount), bgcolor=curBG, text_color=color.white, text_size=size.normal)
    int curBars = bar_index - trendStartBar
    string curDtl = str.tostring(curBars) + "本 HH:" + str.tostring(hhCount) + " HL:" + str.tostring(hlCount) + " LH:" + str.tostring(lhCount) + " LL:" + str.tostring(llCount) + " R:" + str.tostring(resCount)
    table.cell(statTable, 2, 1, curDtl, bgcolor=curBG, text_color=color.white, text_size=size.small)
    // 統計行
    table.cell(statTable, 0, 2, "サンプル数", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 2, str.tostring(n), bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 2, "Up:" + str.tostring(upCount) + " Down:" + str.tostring(dnCount), bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 3, "平均波動数", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 3, str.tostring(avgWaves, "#.#"), bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 3, "Min:" + str.tostring(minWaves, "#") + " Max:" + str.tostring(maxWaves, "#"), bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 4, "平均継続バー数", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 4, str.tostring(avgBars, "#.#"), bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 4, "", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 5, "平均変動率(%)", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 5, str.tostring(avgPct, "#.##") + "%", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 5, "", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 6, "平均ATR倍率", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 6, str.tostring(avgATR, "#.#") + "倍", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 6, "", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 7, "平均HH(高値更新)", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 7, str.tostring(avgHH, "#.#"), bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 7, "", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 8, "平均HL(安値切上)", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 8, str.tostring(avgHL, "#.#"), bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 8, "", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 9, "平均LH(高値切下)", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 9, str.tostring(avgLH, "#.#"), bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 9, "", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 10, "平均LL(安値更新)", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 10, str.tostring(avgLL, "#.#"), bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 10, "", bgcolor=rowBG1, text_color=color.black, text_size=size.small)
    table.cell(statTable, 0, 11, "平均レス回数", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 1, 11, str.tostring(avgRes, "#.#"), bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    table.cell(statTable, 2, 11, "", bgcolor=rowBG2, text_color=color.black, text_size=size.small)
    // 直近トレンド一覧
    table.cell(statTable, 0, 12, "直近トレンド", bgcolor=hdrBG, text_color=hdrTx, text_size=size.small)
    table.cell(statTable, 1, 12, "波動数", bgcolor=hdrBG, text_color=hdrTx, text_size=size.small)
    table.cell(statTable, 2, 12, "変動率 / バー数", bgcolor=hdrBG, text_color=hdrTx, text_size=size.small)
    for i = 0 to 2
        int idx = n - 1 - i
        color rBG = i % 2 == 0 ? rowBG1 : rowBG2
        if idx >= 0
            string dir = array.get(hist_dir, idx)
            int    w   = array.get(hist_waves, idx)
            float  pct = array.get(hist_pct, idx)
            int    b   = array.get(hist_bars, idx)
            int    hh  = array.get(hist_hhCount, idx)
            int    hl  = array.get(hist_hlCount, idx)
            int    lh  = array.get(hist_lhCount, idx)
            int    ll  = array.get(hist_llCount, idx)
            int    res = array.get(hist_resCount, idx)
            color  dCol = dir == "Up" ? color.blue : color.red
            table.cell(statTable, 0, 13 + i, dir, bgcolor=rBG, text_color=dCol, text_size=size.small)
            table.cell(statTable, 1, 13 + i, "W" + str.tostring(w) + " HH:" + str.tostring(hh) + " HL:" + str.tostring(hl) + " LH:" + str.tostring(lh) + " LL:" + str.tostring(ll) + " R:" + str.tostring(res), bgcolor=rBG, text_color=color.black, text_size=size.small)
            table.cell(statTable, 2, 13 + i, str.tostring(pct, "#.#") + "% / " + str.tostring(b) + "本", bgcolor=rBG, text_color=color.black, text_size=size.small)
        else
            table.cell(statTable, 0, 13 + i, "-", bgcolor=rBG, text_color=color.gray, text_size=size.small)
            table.cell(statTable, 1, 13 + i, "-", bgcolor=rBG, text_color=color.gray, text_size=size.small)
            table.cell(statTable, 2, 13 + i, "-", bgcolor=rBG, text_color=color.gray, text_size=size.small)
